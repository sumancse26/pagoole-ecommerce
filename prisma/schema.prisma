// schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Users {
  id                    Int               @id @default(autoincrement())
  user_name             String            @db.VarChar(100)
  email                 String            @unique @db.VarChar(150)
  phone                 String?           @db.VarChar(20)
  password              String?       
  otp                   Int               @default(0) 
  is_admin              Int               @default(1)
  is_active             Int               @default(0)
  created_at            DateTime          @default(now())
  updated_at            DateTime          @updatedAt
  image                 String            @default("") @db.Text
  
  geo_locations         Geo_Locations[]
  vendors               Vendors[]
  carts                 Carts[]
  orders                Orders[]
  wish_lists             Wishlists[]
  shipping_addresses    Shipping_Addresses[]
  product_reviews       Product_Reviews[]
  vendor_reviews        Vendor_Reviews[]
}

model Geo_Locations {
  id                      Int                 @id @default(autoincrement())
  name                    String              @db.VarChar(128)
  loc_type                String?             @default("") @db.VarChar(30)
  full_address            String?             @db.VarChar(255)
  parent_id               Int?
  is_active               Int                 @default(1)
  entry_date              DateTime            @default(now())
  created_by              Int?                
  created_at              DateTime            @default(now())
  updated_at              DateTime            @updatedAt
  
  parent                  Geo_Locations?      @relation("GeoLocationHierarchy", fields: [parent_id], references: [id])
  children                Geo_Locations[]     @relation("GeoLocationHierarchy")
  vendors                 Vendors[]
  users                   Users?               @relation(fields: [created_by], references: [id])
}

model Vendors {
  id                     Int                  @id @default(autoincrement())
  user_id                Int
  store_name             String               @db.VarChar(150)
  store_description      String?              @db.VarChar(500)
  address                String?              @db.VarChar(300)
  location_id            Int
  parent_location_id     Int                  @default(24)
  password               String?       
  otp                    Int                  @default(0)
  is_admin               Int                  @default(0)
  is_active              Int                  @default(0)
  created_at             DateTime             @default(now())
  updated_at             DateTime             @updatedAt
  store_logo             String               @default("") @db.Text
  
  users                  Users                @relation(fields: [user_id], references: [id])
  geo_locations          Geo_Locations        @relation(fields: [location_id], references: [id])
  vendor_products        Vendor_Products[]
  vendor_reviews         Vendor_Reviews[]
}

model Categories {
  id                    Int             @id @default(autoincrement())
  category_name         String          @db.VarChar(100)
  parent_id             Int?
  order_by              Int?
  is_active             Int             @default(1)
  created_at            DateTime        @default(now())
  updated_at            DateTime        @updatedAt
  
  parent                Categories?  @relation("CategoryParent", fields: [parent_id], references: [id])
  children              Categories[] @relation("CategoryParent")
  products              Products[]
  vendor_products       Vendor_Products[]
}

model Brands {
  id                    Int           @id @default(autoincrement())
  name                  String        @unique @db.VarChar(100)
  description           String?       @db.VarChar(500)
  created_at            DateTime      @default(now())
  updated_at            DateTime      @updatedAt
  brand_logo            String        @default("") @db.Text

  products              Products[]
}

model Weights {
  id                    Int           @id @default(autoincrement())
  value                 Int
  unit                  String        @db.VarChar(10)
  description           String?       @db.VarChar(100)
  created_at            DateTime      @default(now())
  updated_at            DateTime      @updatedAt

  products              Products[]
}

model File_Server {
  id                    Int                 @id @default(autoincrement())
  name                  String              @unique @db.VarChar(64) 
  base_url              String              @default("") @db.Text
  created_at            DateTime            @default(now())
  updated_at            DateTime            @updatedAt

  products              Products[]
  product_images        Product_Images[]
}

model Products {
  id                    Int                   @id @default(autoincrement())
  prod_name             String                @db.VarChar(150)
  slug                  String                @db.VarChar(150)
  description           String?               @db.VarChar(512)           
  mrp                   Float           
  vat                   Float                 @default(0)
  brand_id              Int?
  category_id           Int?
  server_id             Int?
  weight_id             Int?
  created_at            DateTime              @default(now())
  updated_at            DateTime              @updatedAt

  brands                Brands?               @relation(fields: [brand_id], references: [id])
  categories            Categories?           @relation(fields: [category_id], references: [id])
  weights               Weights?              @relation(fields: [weight_id], references: [id]) 
  vendor_products       Vendor_Products[]
  vendor_reviews        Product_Reviews[]
  product_images        Product_Images[] 
  file_server           File_Server?          @relation(fields: [server_id], references: [id])
}

model Product_Images {
  id                    Int               @id @default(autoincrement())
  product_id            Int
  vendor_product_id     Int?
  vendor_id             Int
  server_id             Int?
  file_name             String            @db.VarChar(64)
  created_at            DateTime          @default(now())
  updated_at            DateTime          @updatedAt

  products              Products          @relation(fields: [product_id], references: [id])
  vendor_products       Vendor_Products?  @relation(fields: [vendor_product_id], references: [id])
  file_server           File_Server?      @relation(fields: [server_id], references: [id])
}

model Vendor_Products {
  id                     Int             @id @default(autoincrement())
  product_id             Int
  vendor_id              Int
  product_location       Int            @default(null)
  category_id            Int?            
  price                  Float           
  stock_qty              Int             @default(0)
  is_active              Int             @default(1)
  created_at             DateTime        @default(now())
  updated_at             DateTime        @updatedAt

  products               Products        @relation(fields: [product_id], references: [id]) 
  vendors                Vendors         @relation(fields: [vendor_id], references: [id])
  categories             Categories?     @relation(fields: [category_id], references: [id])
  
  cart_items             Cart_Items[]
  order_items            Order_Items[]
  product_images         Product_Images[]
  wish_lists             Wishlists[]
}

model Carts {
  id                     Int             @id @default(autoincrement())
  user_id                Int
  created_at             DateTime        @default(now())
  updated_at             DateTime        @updatedAt
  
  users                  Users           @relation(fields: [user_id], references: [id])
  cart_items             Cart_Items[]
}

model Cart_Items {
  id                     Int             @id @default(autoincrement())
  cart_id                Int
  vendor_prod_id         Int
  qty                    Int             @default(1)
  created_at             DateTime        @default(now())
  updated_at             DateTime        @updatedAt

  carts                  Carts           @relation(fields: [cart_id], references: [id], onDelete: Cascade)
  vendor_products        Vendor_Products @relation(fields: [vendor_prod_id], references: [id])
}

model Orders {
  id                    Int             @id @default(autoincrement())
  user_id               Int
  order_code            String?         @default("")
  delivery_address      Int             @default(0)
  total_amount          Float          
  order_status          String          @default("Pending") @db.VarChar(20)
  payment_method        String          @default("cod") @db.VarChar(15)
  payment_status        String          @default("Unpaid") @db.VarChar(20)
  created_at            DateTime        @default(now())
  updated_at            DateTime        @updatedAt
  
  users                 Users           @relation(fields: [user_id], references: [id])
  order_items           Order_Items[]
  Payments              Payments[]
}

model Order_Items {
  id                    Int             @id @default(autoincrement())
  order_id              Int
  vendor_product_id     Int
  quantity              Int             @default(1)
  unit_price            Float           
  created_at            DateTime        @default(now())
  updated_at            DateTime        @updatedAt

  orders                Orders          @relation(fields: [order_id], references: [id], onDelete: Cascade)
  vendor_products       Vendor_Products @relation(fields: [vendor_product_id], references: [id])
}

model Payments {
  id                    Int             @id @default(autoincrement())
  order_id              Int
  payment_method        String?         @db.VarChar(50)
  payment_date          DateTime?       @default(now())
  amount                Float           
  status                String          @default("Pending") @db.VarChar(20)
  created_at            DateTime        @default(now())
  updated_at            DateTime        @updatedAt

  orders                Orders          @relation(fields: [order_id], references: [id])
}

model Shipping_Addresses {
  id                    Int             @id @default(autoincrement())
  user_id               Int
  full_name             String?         @db.VarChar(100)
  phone                 String?         @db.VarChar(20)
  address_line          String?         @db.VarChar(300)
  region                String?         @db.VarChar(100)
  city                  String?         @db.VarChar(100)
  area                  String?         @db.VarChar(100)
  postal_code           String?         @db.VarChar(20)
  country               String?         @db.VarChar(100)
  address_type          String?         @default("home")
  default_address       String?         @default("0")
  created_at            DateTime        @default(now())
  updated_at            DateTime        @updatedAt
  
  users                 Users           @relation(fields: [user_id], references: [id])
}

model Product_Reviews {
  id                    Int             @id @default(autoincrement())
  product_id            Int
  user_id               Int
  rating                Int            
  remarks               String?         @db.VarChar(1000)
  created_at            DateTime        @default(now())
  updated_at            DateTime        @updatedAt
  
  products              Products        @relation(fields: [product_id], references: [id])
  users                 Users           @relation(fields: [user_id], references: [id])
}

model Vendor_Reviews {
  id                    Int             @id @default(autoincrement())
  vendor_id             Int
  user_id               Int
  rating                Int       
  remarks               String?         @db.VarChar(1000)
  created_at            DateTime        @default(now())
  updated_at            DateTime        @updatedAt
  
  vendors               Vendors         @relation(fields: [vendor_id], references: [id])
  users                 Users           @relation(fields: [user_id], references: [id])
}
model Wishlists {
  id                    Int             @id @default(autoincrement())
  user_id               Int
  vendor_prod_id        Int             
  created_at            DateTime        @default(now())
  updated_at            DateTime        @updatedAt
  
  users                 Users           @relation(fields: [user_id], references: [id])
  vendor_products       Vendor_Products @relation(fields: [vendor_prod_id], references: [id])
}
